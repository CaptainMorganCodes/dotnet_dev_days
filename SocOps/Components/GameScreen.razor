@using SocOps.Models

<div class="flex flex-col min-h-full bg-ship">
    <!-- Header -->
    <header class="flex items-center justify-between p-3 bg-paper border-b border-wood">
        <button
            @onclick="OnReset"
            class="text-paper-muted text-sm px-3 py-1.5 rounded active:bg-wood">
            ← Drop anchor
        </button>
        <h1 class="font-bold text-paper">Pirate Bingo</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-paper-muted text-sm py-2 px-4">
        Tap a square when you find a crew member who fits the clue.
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="bg-gold text-black text-center py-2 font-semibold text-sm rounded-3xl mx-4">
            🏴‍☠️ X marks the spot! Treasure claimed!
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
