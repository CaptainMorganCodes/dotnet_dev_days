<div class="flex flex-col items-center justify-center min-h-full p-6 bg-ship">
    <div class="text-center max-w-sm">
        <h1 class="text-5xl font-bold text-gold mb-2">Pirate Bingo</h1>
        <p class="text-lg text-paper-muted mb-8">Set sail and mark the crew as you find them.</p>

        <div class="bg-paper rounded-3xl p-6 shadow-pirate border border-wood mb-8">
            <h2 class="font-semibold text-paper mb-3">Instructions</h2>
            <ul class="text-left text-paper-muted text-sm space-y-2">
                <li>• Seek salty sailors who fit the clues.</li>
                <li>• Tap a square when you find a match.</li>
                <li>• Claim a row of five and shout “X marks the spot!”</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="w-full bg-gold text-black font-semibold py-4 px-8 rounded-3xl text-lg hover:bg-gold-dark transition-colors">
            Hoist the sails
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
